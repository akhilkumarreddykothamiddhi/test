	partition Query1 = m
		mode: import
		source = ```
				let
				    Source = Sql.Database("10.10.10.73", "school_db_olap_final", [Query="SELECT 
				    fa.school_key, -- Add this!
				    DATEFROMPARTS(LEFT(fa.date_key, 4), SUBSTRING(CAST(fa.date_key AS VARCHAR), 5, 2), 1) AS Month_Starting,
				    (SUM(CAST(fa.days_present AS FLOAT)) / NULLIF(SUM(CAST(fa.total_days AS FLOAT)), 0)) * 100.0 AS Monthly_Attendance_Percent,
				    DATENAME(MONTH, DATEFROMPARTS(LEFT(fa.date_key, 4), SUBSTRING(CAST(fa.date_key AS VARCHAR), 5, 2), 1)) AS Month_Name,
				    fa.academic_year
				FROM fact_attendance fa WITH (NOLOCK)
				GROUP BY 
				    fa.school_key, -- And this!
				    DATEFROMPARTS(LEFT(fa.date_key, 4), SUBSTRING(CAST(fa.date_key AS VARCHAR), 5, 2), 1),
				    fa.academic_year
				ORDER BY Month_Starting ASC;"])
				in
				    Source
				```

