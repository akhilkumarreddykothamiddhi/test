	measure '% Teachers by Gender' = ```
			
			VAR CurrentGenderTeachers = DISTINCTCOUNT(fact_teaching_assignment[staff_key])
			VAR TotalActiveTeachers = 
			    CALCULATE(
			        DISTINCTCOUNT(fact_teaching_assignment[staff_key]), 
			        ALL(dim_staff[gender])
			    )
			RETURN
			DIVIDE(CurrentGenderTeachers, TotalActiveTeachers, 0)
			```
		lineageTag: d61349b6-ef99-4db1-8be2-f901d30ab958

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Teachers by Race' = ```
			
			VAR CurrentRaceTeachers = DISTINCTCOUNT(fact_teaching_assignment[staff_key])
			VAR TotalActiveTeachers = 
			    CALCULATE(
			        DISTINCTCOUNT(fact_teaching_assignment[staff_key]), 
			        ALL(dim_race[race_name])
			    )
			RETURN
			DIVIDE(CurrentRaceTeachers, TotalActiveTeachers, 0)
			```
		lineageTag: ad295e21-51ca-4d23-a1b7-9083f9297827

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Student Teacher Ratio' =
			
			DIVIDE(
			    DISTINCTCOUNT(dim_student[student_key]),
			    DISTINCTCOUNT(dim_staff[staff_id])
			)
		formatString: 0
		lineageTag: c268c894-ee79-45a8-af9c-96ce2f0055ad

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Student Teacher Ratio Growth %' =
			
			VAR CurrentStudents =
			    CALCULATE(
			        DISTINCTCOUNT(dim_student[student_key]),
			        YEAR(dim_student[admission_date]) = YEAR(TODAY())
			    )
			
			VAR PreviousStudents =
			    CALCULATE(
			        DISTINCTCOUNT(dim_student[student_key]),
			        YEAR(dim_student[admission_date]) = YEAR(TODAY()) - 1
			    )
			
			VAR Teachers =
			    DISTINCTCOUNT(dim_staff[staff_id])
			
			VAR CurrentRatio =
			    DIVIDE(CurrentStudents, Teachers)
			
			VAR PreviousRatio =
			    DIVIDE(PreviousStudents, Teachers)
			
			RETURN
			DIVIDE(
			    CurrentRatio - PreviousRatio,
			    PreviousRatio
			) * 100
		lineageTag: 3bfde9de-990f-445f-979e-2b79c3061c48

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Teachers by Socioeconomic status' =
			
			DIVIDE(
			    COUNTROWS(dim_staff),
			    CALCULATE(COUNTROWS(dim_staff), ALL(dim_socioeconomic_status[id]))
			) * 100
		lineageTag: 890c8060-bb55-40ab-ad90-d2accb682e54

		annotation PBI_FormatHint = {"isGeneralNumber":true}

