table fact_teaching_assignment
	lineageTag: cba0e78b-0390-4c3d-97a6-c401623193da

	measure 'Students FLL' =
			
			VAR CurrentSubject = SELECTEDVALUE(dim_subject[subject_name])
			RETURN
			IF(
			    ISINSCOPE(dim_subject[subject_name]),
			    -- This part runs for the Table/Bar Chart rows
			    DISTINCTCOUNT(fact_teaching_assignment[student_key]),
			    -- This part runs for the Card (or the Table Total row)
			    CALCULATE(
			        DISTINCTCOUNT(fact_teaching_assignment[student_key]),
			        dim_subject[subject_name] = "Foriegn Language"
			    )
			)
		formatString: 0
		lineageTag: e9aba0f9-4299-41fc-a5c4-4950ff12cb9f

